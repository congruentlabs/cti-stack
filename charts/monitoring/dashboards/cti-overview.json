  "panels": [
    {
      "title": "CTI Stack Pod Status",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace=~\"cti-.*\", phase=\"Running\"})",
          "legendFormat": "Running Pods"
        }
      ]
    },
    {
      "title": "CTI Stack Memory Usage",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=~\"cti-.*\"}) by (namespace)",
          "legendFormat": "{{namespace}}"
        }
      ]
    },
    {
      "title": "CTI Stack CPU Usage",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"cti-.*\"}[5m])) by (namespace)",
          "legendFormat": "{{namespace}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["cti-stack"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "title": "CTI Stack Overview",
  "uid": "cti-stack-overview"
